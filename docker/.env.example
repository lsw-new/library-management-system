# ==================== 数据库 ====================
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=library_db
MYSQL_USER=library_user
MYSQL_PASSWORD=library_pass

# ==================== Flask ====================
# 生产环境务必修改为随机长字符串
SECRET_KEY=change-me-in-production
FLASK_ENV=production

# ==================== 邮件（可选）====================
# QQ 邮箱 SMTP，用于发送验证码
SMTP_SENDER_EMAIL=
SMTP_SENDER_PASSWORD=

# ==================== 端口 ====================
APP_PORT=5000
MYSQL_PORT=3306
NGINX_PORT=80

# ==================== 镜像 ====================
# 应用镜像（已发布多架构 amd64+arm64）。如需指定版本可改 tag，例如 :v1.2.0
APP_IMAGE=lsw3435255848/library_web:latest
