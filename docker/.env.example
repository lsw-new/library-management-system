# ==================== 数据库 ====================
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=library_db
MYSQL_USER=library_user
MYSQL_PASSWORD=library_pass

# ==================== Flask ====================
# 生产环境务必修改为随机长字符串
SECRET_KEY=change-me-in-production
FLASK_ENV=production

# ==================== 邮件（可选）====================
# QQ 邮箱 SMTP，用于发送验证码
SMTP_SENDER_EMAIL=
SMTP_SENDER_PASSWORD=

# ==================== 端口 ====================
APP_PORT=5000
MYSQL_PORT=3306
NGINX_PORT=80
